ter;vertical-align:middle;background:rgba(203,87,42,0.08);border-bottom:2px solid #CB572A;\">\n          <div style=\"color:#CB572A;font-size:clamp(12px,3.5vw,15px);font-weight:500;margin-bottom:5px;\">Our Pen</div>\n          <span class=\"badge\">Best choice</span>\n        </th>\n        <th style=\"width:31%;text-align:center;vertical-align:middle;background:#fafafa;border-bottom:1px solid #e8e8e8;\">\n          <div style=\"color:#111;font-size:clamp(12px,3.5vw,15px);font-weight:500;margin-bottom:5px;\">Microblading</div>\n          <span class=\"badge-gray\">Salon</span>\n        </th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr><td colspan=\"3\" class=\"cat\">Cost</td></tr>\n      <tr>\n        <td class=\"row-label\">Price</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span style=\"color:#CB572A;font-weight:500;font-size:12px;\">Under $20</span></td>\n        <td style=\"text-align:center;color:#888;font-size:12px;\">$400–$900</td>\n      </tr>\n      <tr>\n        <td class=\"row-label\">Touch-up costs</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span style=\"color:#CB572A;font-weight:500;font-size:12px;\">None</span></td>\n        <td style=\"text-align:center;color:#888;font-size:12px;\">$150–$300</td>\n      </tr>\n      <tr><td colspan=\"3\" class=\"cat\">Convenience</td></tr>\n      <tr>\n        <td class=\"row-label\">Done at home</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span class=\"chk\">✓</span></td>\n        <td style=\"text-align:center;\"><span class=\"crs\">✕</span></td>\n      </tr>\n      <tr><td colspan=\"3\" class=\"cat\">Results</td></tr>\n      <tr>\n        <td class=\"row-label\">Natural hair strokes</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span class=\"chk\">✓</span></td>\n        <td style=\"text-align:center;\"><span style=\"color:#aaa;font-size:13px;\">✓</span></td>\n      </tr>\n      <tr>\n        <td class=\"row-label\">Change shape anytime</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span class=\"chk\">✓</span></td>\n        <td style=\"text-align:center;\"><span class=\"crs\">✕</span></td>\n      </tr>\n      <tr><td colspan=\"3\" class=\"cat\">Safety & commitment</td></tr>\n      <tr>\n        <td class=\"row-label\">Pain-free</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span class=\"chk\">✓</span></td>\n        <td style=\"text-align:center;\"><span class=\"crs\">✕</span></td>\n      </tr>\n      <tr>\n        <td class=\"row-label\">Non-permanent</td>\n        <td class=\"col-our\" style=\"text-align:center;\"><span class=\"chk\">✓</span></td>\n        <td style=\"text-align:center;\"><span class=\"crs\">✕</span></td>\n      </tr>\n    </tbody>\n  </table>\n  <div style=\"background:rgba(203,87,42,0.08);border-top:1px solid rgba(203,87,42,0.2);padding:12px 14px;font-size:12px;color:#666;line-height:1.5;\">\n    💡 Same natural result. <strong style=\"color:#CB572A;\">Minus the needle, the bill, and the waiting room.</strong>\n  </div>\n</div>",
